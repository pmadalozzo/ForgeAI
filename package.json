{
  "name": "forgeai",
  "private": true,
  "version": "0.1.0",
  "description": "Plataforma de fábrica de software autônoma com agentes de IA",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "NODE_ENV=development tsx src/backend/index.ts",
    "dev:full": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "build:backend": "tsc src/backend/**/*.ts --outDir dist/backend",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\""
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/redis": "^7.2.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.48",
    "@supabase/supabase-js": "^2.49.1",
    "bullmq": "^5.34.8",
    "fastify": "^5.2.1",
    "framer-motion": "^12.4.7",
    "ioredis": "^5.4.2",
    "isomorphic-git": "^1.27.2",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reactflow": "^11.11.4",
    "simple-git": "^3.27.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
