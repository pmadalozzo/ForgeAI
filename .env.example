# =============================================================================
# ForgeAI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores necessários
# =============================================================================

# ========================
# Supabase (obrigatório para funcionalidades online)
# Obtenha em: https://supabase.com/dashboard → Settings → API
# Para desenvolvimento local: npx supabase start (usa valores do config.toml)
# ========================
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================
# LLM Providers (opcional — configure conforme necessário)
# Pelo menos um provider é recomendado para que os agentes funcionem
# ========================

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=

# OpenAI (GPT/Codex) — https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# Google AI (Gemini) — https://aistudio.google.com/apikey
VITE_GOOGLE_AI_API_KEY=

# ========================
# Provedores Locais (opcional — sem custo, requer GPU)
# ========================

# Ollama — https://ollama.com (padrão: localhost:11434)
VITE_OLLAMA_BASE_URL=http://localhost:11434

# LM Studio — https://lmstudio.ai (padrão: localhost:1234)
VITE_LMSTUDIO_BASE_URL=http://localhost:1234

# ========================
# GitHub OAuth App (para autenticação via Device Flow)
# Crie em: https://github.com/settings/applications/new
# Homepage URL: http://localhost:1420
# Callback URL: http://localhost:1420/auth/callback
# ========================
VITE_GITHUB_CLIENT_ID=

# ========================
# Redis (Event Bus — BullMQ)
# Só necessário quando ativar workers distribuídos (produção)
# ========================
# REDIS_URL=redis://localhost:6379
